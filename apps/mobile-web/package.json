{
  "name": "mobile-web",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --dev-client --port 8084",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web --port 8084",
    "build": "pnpm generate-icons && expo export --platform web --output-dir dist && pnpm copy-public",
    "generate-icons": "node scripts/generate-pwa-icons.js",
    "copy-public": "node scripts/copy-public-files.js",
    "build:sw": "workbox injectManifest workbox-config.js",
    "lint": "eslint app --ext .ts,.tsx",
    "typecheck": "echo '⚠️  TypeScript check disabled for mobile-web due to Tamagui type recursion (see TAMAGUI_TYPECHECK.md)' && exit 0"
  },
  "dependencies": {
    "@better-auth/expo": "^1.4.18",
    "@expo-google-fonts/montserrat": "^0.4.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@repo/api-client": "workspace:*",
    "@repo/shared": "workspace:*",
    "@repo/ui": "workspace:*",
    "@tamagui/config": "2.0.0-rc.22",
    "burnt": "^0.13.0",
    "expo": "~55.0.4",
    "expo-apple-authentication": "^55.0.8",
    "expo-application": "^55.0.8",
    "expo-crypto": "^55.0.8",
    "expo-dev-client": "~55.0.10",
    "expo-device": "~55.0.9",
    "expo-font": "^55.0.4",
    "expo-image-manipulator": "^55.0.9",
    "expo-image-picker": "^55.0.10",
    "expo-linking": "^55.0.7",
    "expo-localization": "^55.0.8",
    "expo-network": "^55.0.8",
    "expo-router": "~55.0.3",
    "expo-secure-store": "^55.0.8",
    "expo-sqlite": "^55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-updates": "~55.0.12",
    "expo-web-browser": "^55.0.9",
    "hono": "^4.11.4",
    "i18next": "^25.7.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.71.1",
    "react-i18next": "^16.5.3",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.7.2",
    "tamagui": "2.0.0-rc.22",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@tamagui/babel-plugin": "2.0.0-rc.22",
    "@types/react": "~19.2.10",
    "typescript": "~5.9.3",
    "workbox-cli": "^7.4.0"
  },
  "optionalDependencies": {
    "sharp": "^0.34.5"
  },
  "private": true
}
