{
  "name": "mobile-web",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --port 8084",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web --port 8084",
    "build": "pnpm generate-icons && expo export --platform web --output-dir dist && pnpm copy-public",
    "generate-icons": "node scripts/generate-pwa-icons.js",
    "copy-public": "node scripts/copy-public-files.js",
    "build:sw": "workbox injectManifest workbox-config.js",
    "lint": "eslint app --ext .ts,.tsx",
    "typecheck": "echo '⚠️  TypeScript check disabled for mobile-web due to Tamagui type recursion (see TAMAGUI_TYPECHECK.md)' && exit 0"
  },
  "dependencies": {
    "@better-auth/expo": "^1.4.18",
    "@expo-google-fonts/montserrat": "^0.4.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@repo/api-client": "workspace:*",
    "@repo/shared": "workspace:*",
    "@repo/ui": "workspace:*",
    "@tamagui/config": "1.144.3",
    "@tamagui/portal": "1.144.3",
    "burnt": "^0.13.0",
    "expo": "~54.0.33",
    "expo-apple-authentication": "^7.2.4",
    "expo-application": "^7.0.8",
    "expo-constants": "^18.0.13",
    "expo-crypto": "^15.0.8",
    "expo-device": "^8.0.10",
    "expo-font": "^14.0.11",
    "expo-image-manipulator": "^14.0.8",
    "expo-image-picker": "^17.0.10",
    "expo-linking": "^8.0.11",
    "expo-localization": "^17.0.8",
    "expo-network": "^8.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "^15.0.8",
    "expo-sqlite": "^16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "^15.0.10",
    "hono": "^4.11.4",
    "i18next": "^25.7.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.71.1",
    "react-i18next": "^16.5.3",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-reanimated": "4.1.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2",
    "tamagui": "1.144.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@repo/typescript-config": "workspace:*",
    "@tamagui/babel-plugin": "1.144.3",
    "@types/react": "19.1.17",
    "typescript": "~5.9.3",
    "workbox-cli": "^7.4.0"
  },
  "optionalDependencies": {
    "sharp": "^0.34.5"
  },
  "private": true
}
