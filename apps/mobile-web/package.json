{
  "name": "mobile-web",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --dev-client --port 8084",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web --port 8084",
    "build": "pnpm generate-icons && node scripts/expo-export.js && pnpm copy-public",
    "generate-icons": "node scripts/generate-pwa-icons.js",
    "copy-public": "node scripts/copy-public-files.js",
    "build:sw": "workbox injectManifest workbox-config.js",
    "eas-build-post-install": "node scripts/patch-gradle-jvmargs.js",
    "lint": "eslint app --ext .ts,.tsx",
    "typecheck": "echo '⚠️  TypeScript check disabled for mobile-web due to Tamagui type recursion (see TAMAGUI_TYPECHECK.md)' && exit 0"
  },
  "dependencies": {
    "@better-auth/expo": "^1.6.9",
    "@expo-google-fonts/montserrat": "^0.4.2",
    "@expo/dom-webview": "55.0.5",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@repo/api-client": "workspace:*",
    "@repo/shared": "workspace:*",
    "@repo/ui": "workspace:*",
    "@sentry/react-native": "~7.11.0",
    "@tamagui/config": "2.0.0-rc.41",
    "burnt": "^0.13.0",
    "expo": "~55.0.19",
    "expo-apple-authentication": "^55.0.13",
    "expo-application": "^55.0.14",
    "expo-build-properties": "^55.0.13",
    "expo-crypto": "^55.0.14",
    "expo-dev-client": "~55.0.30",
    "expo-device": "~55.0.15",
    "expo-font": "^55.0.6",
    "expo-image-manipulator": "^55.0.15",
    "expo-image-picker": "^55.0.19",
    "expo-linking": "^55.0.14",
    "expo-localization": "^55.0.13",
    "expo-network": "^55.0.13",
    "expo-notifications": "~55.0.22",
    "expo-router": "~55.0.13",
    "expo-secure-store": "^55.0.13",
    "expo-sqlite": "^55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-updates": "~55.0.21",
    "expo-video": "^55.0.15",
    "expo-video-thumbnails": "^55.0.14",
    "expo-web-browser": "^55.0.14",
    "hono": "^4.12.16",
    "i18next": "^25.10.10",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.75.0",
    "react-i18next": "^16.6.6",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-reanimated": "4.3.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.1",
    "tamagui": "2.0.0-rc.41",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@tamagui/babel-plugin": "2.0.0-rc.41",
    "@types/react": "~19.2.14",
    "typescript": "~5.9.3",
    "workbox-cli": "^7.4.0"
  },
  "optionalDependencies": {
    "sharp": "^0.34.5"
  },
  "private": true
}
