# Database Configuration
STORAGE_PROVIDER=turso
TURSO_DATABASE_URL=libsql://your-database-url.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# For local development, you can use:
# STORAGE_PROVIDER=local-db
# LOCAL_DATABASE_URL=file:./local.db

# Authentication
BETTER_AUTH_SECRET=your_32_character_or_longer_secret
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Server Configuration
PORT=3001

# CORS Configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000

# Trusted Origins for Better Auth (comma-separated)
TRUSTED_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000

# Timezone
DEFAULT_TIMEZONE=Europe/Berlin

# Optional: Sentry
SENTRY_AUTH_TOKEN=your_sentry_token
