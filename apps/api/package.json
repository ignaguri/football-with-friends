{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun dist/index.js",
    "typecheck": "tsc --noEmit",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy",
    "cf:deploy:preview": "wrangler deploy --env preview",
    "cf:tail": "wrangler tail"
  },
  "dependencies": {
    "@better-auth/expo": "^1.5.5",
    "@hono/zod-validator": "^0.7.6",
    "@repo/shared": "workspace:*",
    "@sentry/cloudflare": "^10.45.0",
    "@vercel/blob": "^2.3.1",
    "better-auth": "^1.5.5",
    "hono": "^4.12.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260316.1",
    "@repo/typescript-config": "workspace:*",
    "@types/bun": "^1.3.10",
    "typescript": "^5.9.3",
    "wrangler": "^4.74.0"
  }
}
