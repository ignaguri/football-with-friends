ios/
android/

# Expo root app.json (real config is in apps/mobile-web/app.json)
/app.json

# React Native / Expo
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.hprof

# Expo credentials (local signing)
credentials.json
ios/certs/
android/keystores/

# Expo EAS
eas-metadata.json

# Google OAuth credentials (downloaded from Cloud Console)
client_secret*.json

# Google Play service account key (used by EAS Submit)
google-play-service-account.json

# Misc
.vscode/
.idea/
*.swp
*.swo
*~
.history/
apps/api/.dev.vars
.worktrees/
.memelord/

# Superpowers brainstorm companion session files
.superpowers/

# EAS local build artifacts (loose files at app roots)
apps/mobile-web/build-*.ipa
apps/mobile-web/build-*.aab
apps/mobile-web/build-*.apk

# Wrangler-generated Cloudflare Worker types (regenerate with `wrangler types`)
apps/api/worker-configuration.d.ts
