{
  "name": "football-with-friends-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules",
    "dev:api": "turbo dev --filter=api",
    "dev:app": "turbo dev --filter=mobile-web",
    "migrate": "tsx scripts/migrate.ts",
    "migrate:up": "tsx scripts/migrate.ts up",
    "migrate:down": "tsx scripts/migrate.ts down",
    "migrate:status": "tsx scripts/migrate.ts status",
    "migrate-remote": "tsx scripts/migrate-remote.ts",
    "migrate-remote:up": "tsx scripts/migrate-remote.ts up",
    "migrate-remote:down": "tsx scripts/migrate-remote.ts down",
    "migrate-remote:status": "tsx scripts/migrate-remote.ts status",
    "migrate-remote:dry-run": "tsx scripts/migrate-remote.ts dry-run",
    "migrate-data": "tsx scripts/migrate-data.ts",
    "migrate-data:local": "tsx scripts/migrate-data.ts local",
    "migrate-data:remote": "tsx scripts/migrate-data.ts remote",
    "create-migration": "tsx scripts/create-migration.ts",
    "setup-local-db": "tsx scripts/setup-local-db.ts",
    "seed": "tsx scripts/seed.ts",
    "seed:local": "tsx scripts/seed.ts local",
    "seed:staging": "tsx scripts/seed.ts remote",
    "validate-env": "tsx scripts/validate-env.ts",
    "env:check": "tsx scripts/validate-env.ts check",
    "env:template": "tsx scripts/validate-env.ts template",
    "prepare": "husky",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@libsql/kysely-libsql": "^0.4.1",
    "@tanstack/react-query": "^5.90.21",
    "@vercel/functions": "^3.4.3",
    "better-auth": "^1.5.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "kysely": "^0.28.12",
    "libsql": "^0.5.22",
    "nanoid": "^5.1.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.5.0",
    "@types/react": "~19.2.14",
    "@types/react-dom": "~19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.21.0",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "resolutions": {
    "@types/react": "~19.2.14",
    "@types/react-dom": "~19.2.0",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "unrs-resolver"
    ],
    "overrides": {
      "hono": "^4.12.8",
      "kysely": "^0.28.12",
      "react": "19.2.0",
      "react-dom": "19.2.0"
    }
  },
  "lint-staged": {
    "migrations/**/*.ts": [
      "eslint --fix",
      "tsc --noEmit"
    ],
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
